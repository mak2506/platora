# Fluduro — Environment Variables
# Copy this to .env for local development.
# On Railway / Render / Fly: set these in the dashboard — no .env file needed.

# Your Groq API key — get one at https://console.groq.com/
API_KEY=gsk_your_groq_api_key_here

# Port (Railway sets this automatically; 3553 is the local default)
# PORT=3553

# Enable verbose request logs locally (never set this in production)
# DEV_MODE=true
